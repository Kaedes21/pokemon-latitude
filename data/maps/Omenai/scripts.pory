mapscripts Omenai_MapScripts {
    MAP_SCRIPT_ON_FRAME_TABLE [
        VAR_TEMP_0, 0: InitScript
    ]
}

script InitScript {
    lockall
    msgbox(InitText)
    closemessage
    setflag(FLAG_SYS_B_DASH)         
    setflag(FLAG_RECEIVED_RUNNING_SHOES)
    setvar(VAR_TEMP_0, 1)
    releaseall
}

text InitText {
    "Welcome to Omenai!\n"
    "Explore the area and find hidden secrets!"
}